generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoServico {
  INCLUSAO_VEICULO_NOVO
  TRANSFERENCIA
  PA2
  INTENCAO_DE_VENDA
  OUTROS
}

enum StatusServico {
  PENDENTE
  EM_ANDAMENTO
  AGUARDANDO_IMPRESSAO
  CONCLUIDO
}

enum PapelConta {
  PROPRIETARIO
  MEMBRO
}

model Conta {
  id        String          @id @default(uuid())
  nome      String
  membros   MembroConta[]
  convites  ConviteConta[]
  clientes  Cliente[]
  veiculos  Veiculo[]
  servicos  Servico[]
  processos ProcessoMontagem[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("contas")
}

model MembroConta {
  id        String     @id @default(uuid())
  usuarioId String     @map("usuario_id")
  contaId   String     @map("conta_id")
  papel     PapelConta @default(MEMBRO)
  usuario   Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  conta     Conta      @relation(fields: [contaId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @map("created_at")

  @@unique([usuarioId, contaId])
  @@index([contaId])
  @@map("membros_conta")
}

model ConviteConta {
  id        String     @id @default(uuid())
  contaId   String     @map("conta_id")
  email     String
  token     String     @unique
  criadoPor String     @map("criado_por")
  expiraEm  DateTime   @map("expira_em")
  aceitoEm  DateTime?  @map("aceito_em")
  conta     Conta      @relation(fields: [contaId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([contaId])
  @@map("convites_conta")
}

model Cliente {
  id        String    @id @default(uuid())
  nome      String
  telefone  String?
  cpfCnpj  String    @map("cpf_cnpj")
  contaId  String    @map("conta_id")
  conta    Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  veiculos  Veiculo[]
  servicos  Servico[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([contaId, cpfCnpj])
  @@index([contaId])
  @@map("clientes")
}

model Veiculo {
  id        String    @id @default(uuid())
  placa     String
  modelo    String
  renavam   String
  contaId   String    @map("conta_id")
  conta     Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  clienteId String    @map("cliente_id")
  cliente   Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  servicos  Servico[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([contaId])
  @@unique([contaId, placa])
  @@unique([contaId, renavam])
  @@map("veiculos")
}

model Servico {
  id          String        @id @default(uuid())
  tipo        TipoServico
  status      StatusServico @default(PENDENTE)
  dataLimite  DateTime      @map("data_limite") @db.Date
  observacoes String?
  chassi      String?
  clienteId   String        @map("cliente_id")
  contaId     String        @map("conta_id")
  conta       Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  cliente     Cliente       @relation(fields: [clienteId], references: [id])
  veiculoId   String?       @map("veiculo_id")
  veiculo     Veiculo?      @relation(fields: [veiculoId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([contaId])
  @@map("servicos")
}

model ProcessoMontagem {
  id                String          @id @default(uuid())
  placa             String
  numeroAtendimento String          @map("numero_atendimento")
  solicitantePa2    String          @default("") @map("solicitante_pa2")
  contaId           String          @map("conta_id")
  conta             Conta           @relation(fields: [contaId], references: [id], onDelete: Cascade)
  status            StatusServico   @default(PENDENTE)
  anexos            ProcessoAnexo[]
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  concluidoEm       DateTime?       @map("concluido_em")

  @@index([contaId])
  @@map("processos_montagem")
}

model ProcessoAnexo {
  id         String           @id @default(uuid())
  nome       String
  mimeType   String           @map("mime_type")
  tamanho    Int
  conteudo   Bytes
  processoId String           @map("processo_id")
  processo   ProcessoMontagem @relation(fields: [processoId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now()) @map("created_at")

  @@map("processos_anexos")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String   @map("senha_hash")
  membros   MembroConta[]
  lembretes Lembrete[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuarios")
}

model Lembrete {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String?
  dataLembrete  DateTime? @map("data_lembrete") @db.Date
  concluido     Boolean  @default(false)
  usuarioId     String   @map("usuario_id")
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([usuarioId])
  @@map("lembretes")
}
